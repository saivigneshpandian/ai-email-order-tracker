    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const status = (item.json.Status || item.json[\"Status \"] || \"\")\n    .trim()\n    .toLowerCase();\n\n  let listId = \"\";\n\n  if (status === \"new\") {\n    listId = \"69d0b207bf37b21738ff9677\"; // To Do\n  } else if (status === \"in production\") {\n    listId = \"69d0b207bf37b21738ff9678\"; // Doing\n  } else if (status === \"shipped\" || status === \"delivered\") {\n    listId = \"69d0b207bf37b21738ff9679\"; // Done\n  } else {\n    listId = \"69d0b207bf37b21738ff9677\"; // Default\n  }\n\n  item.json.listId = listId;\n  return item;\n});"
      },
